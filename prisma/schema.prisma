generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RegionTag {
  JS
}

enum MistakeStatus {
  DRAFT
  REVIEWED
}

enum AiTaskType {
  OCR
  EXPLANATION_REWRITE
  VARIANT_GENERATION
}

enum AiTaskStatus {
  PENDING
  COMPLETED
  FAILED
  SKIPPED
}

enum PracticePackStatus {
  DRAFT
  CONFIRMED
}

enum ReviewTermMode {
  TERM
  HOLIDAY
}

enum ReviewCadence {
  WEEKLY_WEEKEND
  BIWEEKLY_WEEKEND
  MONTHLY_WEEKEND
  HOLIDAY_ONLY
}

enum ReviewResult {
  FORGOT
  PARTIAL
  MASTERED
}

model Teacher {
  id            String         @id @default(cuid())
  name          String
  phone         String?        @unique
  email         String?        @unique
  reviewTermMode ReviewTermMode @default(TERM)
  students      Student[]
  practicePacks PracticePack[]
  textbookExercisePreferences TextbookExercisePreference[]
  textbookExerciseUsages TextbookExerciseUsage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Student {
  id            String         @id @default(cuid())
  name          String
  grade         String         @default("高三")
  school        String?
  province      String         @default("江苏")
  textbookTrack String         @default("苏教版")
  reviewCadence ReviewCadence  @default(WEEKLY_WEEKEND)
  reviewBatchSize Int          @default(8)
  teacherId     String
  teacher       Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  mistakes      Mistake[]
  practicePacks PracticePack[]
  mastery       KnowledgeMastery[]
  reviewRecords ReviewRecord[]
  textbookExerciseUsages TextbookExerciseUsage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([teacherId])
}

model KnowledgePoint {
  id            String                  @id @default(cuid())
  code          String                  @unique
  name          String
  module        String
  textbook      String
  chapter       String
  section       String?
  region        RegionTag               @default(JS)
  examWeight    Int                     @default(1)
  parentId      String?
  parent        KnowledgePoint?         @relation("KnowledgeTree", fields: [parentId], references: [id])
  children      KnowledgePoint[]        @relation("KnowledgeTree")
  mistakeLinks  MistakeKnowledgePoint[]
  textbookItems TextbookExercise[]
  practiceItems PracticeItem[]
  mastery       KnowledgeMastery[]
  createdAt     DateTime                @default(now())

  @@index([module])
  @@index([textbook])
  @@index([region])
}

model TextbookExercise {
  id               String          @id @default(cuid())
  code             String          @unique
  textbook         String
  chapter          String
  section          String?
  sourcePage       Int?
  sourceLabel      String
  prompt           String
  answerText       String?
  analysisText     String?
  difficulty       Int             @default(1)
  knowledgePointId String
  knowledgePoint   KnowledgePoint  @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
  practiceItems    PracticeItem[]
  preferences      TextbookExercisePreference[]
  usages           TextbookExerciseUsage[]
  createdAt        DateTime        @default(now())

  @@index([knowledgePointId])
  @@index([textbook])
}

model ErrorType {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String
  mistakes    Mistake[]
}

model Mistake {
  id              String                  @id @default(cuid())
  studentId       String
  student         Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionText    String?
  answerText      String?
  analysisText    String?
  correctionNote  String?
  imagePath       String?
  imageMimeType   String?
  regionTag       RegionTag               @default(JS)
  sourceYear      Int?
  questionType    String?
  status          MistakeStatus            @default(DRAFT)
  errorTypeId     String?
  errorType       ErrorType?               @relation(fields: [errorTypeId], references: [id])
  aiDraftJson     Json?
  knowledgeLinks  MistakeKnowledgePoint[]
  practiceItems   PracticeItem[]
  aiTasks         AiTask[]
  reviewRecords   ReviewRecord[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  reviewedAt      DateTime?
  reviewDueAt     DateTime?

  @@index([studentId])
  @@index([createdAt])
  @@index([status])
}

model MistakeKnowledgePoint {
  mistakeId        String
  knowledgePointId String
  mistake          Mistake        @relation(fields: [mistakeId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  @@id([mistakeId, knowledgePointId])
  @@index([knowledgePointId])
}

model PracticePack {
  id          String             @id @default(cuid())
  title       String
  teacherId   String
  teacher     Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  regionTag   RegionTag          @default(JS)
  status      PracticePackStatus @default(DRAFT)
  items       PracticeItem[]
  textbookExerciseUsages TextbookExerciseUsage[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  printedAt   DateTime?

  @@index([teacherId])
  @@index([studentId])
}

model PracticeItem {
  id               String          @id @default(cuid())
  packId           String
  pack             PracticePack    @relation(fields: [packId], references: [id], onDelete: Cascade)
  prompt           String
  answerText       String?
  analysisText     String?
  order            Int
  isAiDraft        Boolean         @default(false)
  knowledgePointId String?
  knowledgePoint   KnowledgePoint? @relation(fields: [knowledgePointId], references: [id], onDelete: SetNull)
  textbookExerciseId String?
  textbookExercise   TextbookExercise? @relation(fields: [textbookExerciseId], references: [id], onDelete: SetNull)
  sourceMistakeId  String?
  sourceMistake    Mistake?        @relation(fields: [sourceMistakeId], references: [id], onDelete: SetNull)
  textbookExerciseUsage TextbookExerciseUsage?
  createdAt        DateTime        @default(now())

  @@index([packId])
  @@index([textbookExerciseId])
}

model AiTask {
  id           String       @id @default(cuid())
  type         AiTaskType
  status       AiTaskStatus @default(PENDING)
  provider     String       @default("none")
  mistakeId    String?
  mistake      Mistake?     @relation(fields: [mistakeId], references: [id], onDelete: SetNull)
  inputJson    Json?
  outputJson   Json?
  errorMessage String?
  createdAt    DateTime     @default(now())
  completedAt  DateTime?

  @@index([mistakeId])
  @@index([status])
}

model KnowledgeMastery {
  id               String          @id @default(cuid())
  studentId        String
  student          Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  knowledgePointId String
  knowledgePoint   KnowledgePoint  @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)
  score            Int             @default(50)
  masteredStreak   Int             @default(0)
  forgotCount      Int             @default(0)
  reviewedAt       DateTime?
  nextReviewAt     DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([studentId, knowledgePointId])
  @@index([studentId])
  @@index([knowledgePointId])
  @@index([nextReviewAt])
}

model ReviewRecord {
  id           String       @id @default(cuid())
  studentId    String
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mistakeId    String
  mistake      Mistake      @relation(fields: [mistakeId], references: [id], onDelete: Cascade)
  result       ReviewResult
  note         String?
  scoreAfter   Int?
  reviewedAt   DateTime     @default(now())
  nextReviewAt DateTime?
  createdAt    DateTime     @default(now())

  @@index([studentId])
  @@index([mistakeId])
  @@index([reviewedAt])
  @@index([nextReviewAt])
}

model TextbookExercisePreference {
  id                 String           @id @default(cuid())
  teacherId          String
  teacher            Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  textbookExerciseId String
  textbookExercise   TextbookExercise @relation(fields: [textbookExerciseId], references: [id], onDelete: Cascade)
  isFavorite         Boolean          @default(false)
  note               String?
  difficultyOverride Int?
  isDisabled         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([teacherId, textbookExerciseId])
  @@index([teacherId])
  @@index([textbookExerciseId])
  @@index([isFavorite])
  @@index([isDisabled])
}

model TextbookExerciseUsage {
  id                 String           @id @default(cuid())
  teacherId          String
  teacher            Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId          String
  student            Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  packId             String?
  pack               PracticePack?    @relation(fields: [packId], references: [id], onDelete: SetNull)
  practiceItemId     String?          @unique
  practiceItem       PracticeItem?    @relation(fields: [practiceItemId], references: [id], onDelete: SetNull)
  textbookExerciseId String
  textbookExercise   TextbookExercise @relation(fields: [textbookExerciseId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@index([teacherId])
  @@index([studentId])
  @@index([packId])
  @@index([textbookExerciseId])
  @@index([createdAt])
}
